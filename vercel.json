{
  "version": 2,
  "builds": [
    {
      "src": "api/main.py",
      "use": "@vercel/python"
    },
    {
      "src": "cipherforge-dashboard/package.json",
      "use": "@vercel/static-build",
      "config": {
        "buildCommand": "cd cipherforge-dashboard && npm install --legacy-peer-deps && npm run build",
        "distDir": "cipherforge-dashboard/dist/cipherforge-dashboard"
      }
    }
  ],
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "/api/main.py"
    },
    {
      "handle": "filesystem"
    },
    {
      "src": "/(.*)",
      "dest": "/index.html"
    }
  ]
}
